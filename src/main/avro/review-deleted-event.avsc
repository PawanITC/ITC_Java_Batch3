{
  "type": "record",
  "name": "ReviewDeletedEvent",
  "namespace": "com.itc.funkart.avro",
  "fields": [
    { "name": "eventType", "type": "string", "default": "REVIEW_DELETED" },
    { "name": "reviewId", "type": "long" },
    { "name": "productId", "type": "long" },
    { "name": "userId", "type": "long" },
    { "name": "rating", "type": "int" },
    { "name": "comment", "type": "string" },
    { "name": "createdAt", "type": { "type": "long", "logicalType": "timestamp-millis" } },
    { "name": "deletedAt", "type": { "type": "long", "logicalType": "timestamp-millis" } },
    { "name": "payload", "type": "com.example.events.common.ReviewPayload" }
  ]
}

