pipeline {
    agent {
        kubernetes {
            yaml '''
                apiVersion: v1
                kind: Pod
                spec:
                  containers:
                  - name: kaniko
                    image: gcr.io/kaniko-project/executor:latest
                    command:
                    - cat
                    tty: true
                  - name: kubectl
                    image: bitnami/kubectl:latest
                    command:
                    - cat
                    tty: true
                  serviceAccountName: jenkins-sa
            '''
        }
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
    }

    parameters {
        string(name: 'GIT_BRANCH', defaultValue: 'feature-anjali', description: 'Git branch to build')
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Docker image tag')
    }

    environment {
        // AWS ECR Details
        AWS_ACCOUNT_ID = '666127452756'
        AWS_REGION = 'eu-west-2'
        ECR_REPO_NAME = 'ecr-java'
        ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        IMAGE_NAME = "${ECR_REGISTRY}/${ECR_REPO_NAME}"
        IMAGE_TAG = "${params.IMAGE_TAG ?: env.BUILD_NUMBER}"

        // Kubernetes
        K8S_NAMESPACE = 'order-service'
        K8S_DEPLOYMENT = 'order-service'
        K8S_CLUSTER_NAME = 'tf-java-eks-jn7re'

        // GitHub
        GITHUB_REPO = 'https://github.com/PawanITC/ITC_Java_Batch3.git'
        SERVICE_PATH = 'backend/order-service'
    }

    stages {
        stage('🔍 Checkout Code') {
            steps {
                script {
                    echo "========== STAGE 1: Checkout Code =========="
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "*/${params.GIT_BRANCH}"]],
                        userRemoteConfigs: [[url: "${GITHUB_REPO}"]]
                    ])
                    echo "✅ Code checked out from ${params.GIT_BRANCH}"
                    echo "📂 Service path: ${SERVICE_PATH}"

                    // List files to verify
                    sh '''
                        echo "Directory structure:"
                        ls -la ${SERVICE_PATH}/
                        echo ""
                        echo "Files present:"
                        ls -la ${SERVICE_PATH}/Dockerfile || echo "❌ Dockerfile not found"
                        ls -la ${SERVICE_PATH}/pom.xml || echo "❌ pom.xml not found"
                    '''
                }
            }
        }

        stage('📊 Build Information') {
            steps {
                script {
                    echo "========== STAGE 2: Build Information =========="
                    echo "📦 Docker Image: ${IMAGE_NAME}:${IMAGE_TAG}"
                    echo "🏢 AWS Account: ${AWS_ACCOUNT_ID}"
                    echo "🌍 AWS Region: ${AWS_REGION}"
                    echo "🐳 ECR Repository: ${ECR_REPO_NAME}"
                    echo "☸️  K8S Namespace: ${K8S_NAMESPACE}"
                    echo "🔗 GitHub Repo: ${GITHUB_REPO}"
                    echo "🌿 Branch: ${params.GIT_BRANCH}"
                    echo "📁 Service: ${SERVICE_PATH}"
                    echo "✅ Build info logged"
                }
            }
        }

        stage('🔐 AWS Authentication') {
            steps {
                script {
                    echo "========== STAGE 3: AWS Authentication =========="
                    container('kaniko') {
                        withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                            sh '''
                                echo "Authenticating with AWS ECR..."
                                aws ecr get-login-password --region ${AWS_REGION} | \
                                docker login --username AWS --password-stdin ${ECR_REGISTRY}
                                echo "✅ AWS ECR authenticated"
                            '''
                        }
                    }
                }
            }
        }

        stage('🐳 Build Docker Image (Kaniko)') {
            steps {
                script {
                    echo "========== STAGE 4: Build Docker Image =========="
                    container('kaniko') {
                        sh '''
                            echo "Building Docker image with Kaniko..."
                            echo "Context: ${SERVICE_PATH}"

                            cd ${SERVICE_PATH}

                            /kaniko/executor \
                                --context=. \
                                --dockerfile=Dockerfile \
                                --destination=${IMAGE_NAME}:${IMAGE_TAG} \
                                --destination=${IMAGE_NAME}:latest \
                                --cache=true \
                                --cache-repo=${IMAGE_NAME}/cache

                            echo "✅ Docker image built and pushed to ECR"
                        '''
                    }
                }
            }
        }

        stage('📤 Verify ECR Push') {
            steps {
                script {
                    echo "========== STAGE 5: Verify ECR Push =========="
                    container('kaniko') {
                        withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                            sh '''
                                echo "Verifying image in ECR..."
                                aws ecr describe-images \
                                    --repository-name ${ECR_REPO_NAME} \
                                    --region ${AWS_REGION} \
                                    --query 'imageDetails[0:5].[imageTags,imagePushedAt]' \
                                    --output table
                                echo "✅ Image verified in ECR"
                            '''
                        }
                    }
                }
            }
        }

        stage('☸️  Update K8S Deployment') {
            steps {
                script {
                    echo "========== STAGE 6: Update K8S Deployment =========="
                    container('kubectl') {
                        withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                            sh '''
                                # Configure kubectl
                                echo "Configuring kubectl..."
                                aws eks update-kubeconfig --region ${AWS_REGION} --name ${K8S_CLUSTER_NAME}

                                # Check current deployment
                                echo "Current deployment image:"
                                kubectl get deployment ${K8S_DEPLOYMENT} -n ${K8S_NAMESPACE} -o jsonpath='{.spec.template.spec.containers[0].image}'
                                echo ""
                                echo ""

                                # Update image
                                echo "Updating deployment with new image: ${IMAGE_NAME}:${IMAGE_TAG}"
                                kubectl set image deployment/${K8S_DEPLOYMENT} \
                                    ${K8S_DEPLOYMENT}=${IMAGE_NAME}:${IMAGE_TAG} \
                                    -n ${K8S_NAMESPACE}

                                # Wait for rollout
                                echo "Waiting for rollout to complete (timeout: 5m)..."
                                kubectl rollout status deployment/${K8S_DEPLOYMENT} -n ${K8S_NAMESPACE} --timeout=5m

                                echo "✅ Deployment updated successfully"
                            '''
                        }
                    }
                }
            }
        }

        stage('✅ Verify Deployment') {
            steps {
                script {
                    echo "========== STAGE 7: Verify Deployment =========="
                    container('kubectl') {
                        withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                            sh '''
                                aws eks update-kubeconfig --region ${AWS_REGION} --name ${K8S_CLUSTER_NAME}

                                echo "Pod Status:"
                                kubectl get pods -n ${K8S_NAMESPACE} -l app=order-service -o wide
                                echo ""

                                echo "Service Status:"
                                kubectl get svc order-service -n ${K8S_NAMESPACE} -o wide
                                echo ""

                                echo "Deployment Status:"
                                kubectl get deployment order-service -n ${K8S_NAMESPACE} -o wide
                                echo ""

                                echo "Recent Pod Logs (last 30 lines):"
                                kubectl logs -n ${K8S_NAMESPACE} -l app=order-service --tail=30 || echo "Logs not available yet"

                                echo ""
                                echo "✅ Deployment verified"
                            '''
                        }
                    }
                }
            }
        }

        stage('📊 Health Check') {
            steps {
                script {
                    echo "========== STAGE 8: Health Check =========="
                    container('kubectl') {
                        withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                            sh '''
                                aws eks update-kubeconfig --region ${AWS_REGION} --name ${K8S_CLUSTER_NAME}

                                echo "Getting Service External IP..."
                                SERVICE_IP=$(kubectl get svc order-service -n ${K8S_NAMESPACE} -o jsonpath='{.status.loadBalancer.ingress[0].hostname}')
                                echo "Service IP/DNS: $SERVICE_IP"

                                if [ -z "$SERVICE_IP" ]; then
                                    echo "⚠️  External IP not assigned yet (might take a moment)"
                                else
                                    echo "Attempting health check..."
                                    curl -f http://$SERVICE_IP/health || echo "⚠️  Health check endpoint not ready yet"
                                fi
                            '''
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                echo "=========================================="
                echo "✅ PIPELINE SUCCESS"
                echo "=========================================="
                echo "Docker Image: ${IMAGE_NAME}:${IMAGE_TAG}"
                echo "Deployed to: ${K8S_NAMESPACE}/${K8S_DEPLOYMENT}"
                echo "Region: ${AWS_REGION}"
                echo "Repository: ${GITHUB_REPO}"
                echo "Branch: ${params.GIT_BRANCH}"
                echo "=========================================="
            }
        }
        failure {
            script {
                echo "=========================================="
                echo "❌ PIPELINE FAILED"
                echo "=========================================="
                echo "Stage: ${env.STAGE_NAME}"
                echo "Build Number: ${env.BUILD_NUMBER}"
                echo "Check logs above for details"
                echo "=========================================="
            }
        }
        always {
            script {
                echo "Build Duration: ${currentBuild.durationString}"
            }
        }
    }
}