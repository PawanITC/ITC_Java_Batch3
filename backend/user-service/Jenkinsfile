pipeline {
    agent any

    tools {
        jdk 'jdk17'
    }

    environment {
        DOCKER_HUB_USER = 'abbasgureitc'
        IMAGE_NAME = 'user-service'
        REGISTRY_CREDENTIALS_ID = 'docker-hub-credentials'
        SNYK_TOKEN = credentials('snyk-token')
        dockerImage = ''
    }

    stages {
        stage('Check Environment') {
            steps {
                sh 'java -version'
                sh 'docker version'
            }
        }

        stage('Build & Test') {
            steps {
                dir('backend/user-service') {
                    script {
                        def jdkPath = tool name: 'jdk17', type: 'jdk'
                        withEnv(["JAVA_HOME=${jdkPath}", "PATH+JDK=${jdkPath}/bin"]) {
                            sh 'chmod +x gradlew'
                            // Added --no-daemon to prevent Jenkins workspace locking
                            sh "./gradlew clean build jacocoTestReport --no-daemon -Dorg.gradle.java.home=${jdkPath}"
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                // Modern replacement for the deprecated Jacoco plugin
                recordCoverage(
                    tools: [[parser: 'JACOCO', pattern: '**/build/reports/jacoco/test/*.xml']],
                    id: 'user-service-coverage',
                    name: 'User Service Coverage',
                    sourceCodeRetention: 'LAST_BUILD',
                    // This sets your 70% threshold as a health gate
                    qualityGates: [[threshold: 70.0, metric: 'LINE', baseline: 'PROJECT', unstable: true]]
                )
            }
        }

        stage('Security Scan (Snyk)') {
            steps {
                dir('backend/user-service') {
                    script {
                        sh 'chmod +x gradlew'
                        sh "snyk auth ${SNYK_TOKEN}"
                        // Now that we've aligned Jackson, Snyk should be much happier!
                        sh 'snyk test --severity-threshold=high || echo "Snyk found high-severity vulnerabilities"'
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('backend/user-service') {
                    script {
                        currentBuild.displayName = "#${env.BUILD_NUMBER} - ${IMAGE_NAME}"
                        // Ensure your Dockerfile is actually inside backend/user-service/
                        dockerImage = docker.build("${DOCKER_HUB_USER}/${IMAGE_NAME}:${env.BUILD_NUMBER}", ".")
                    }
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    docker.withRegistry('', REGISTRY_CREDENTIALS_ID) {
                        dockerImage.push()
                        dockerImage.push('latest')
                    }
                }
            }
        }
    }

    post {
        success { echo "SUCCESS: ${IMAGE_NAME} is live on Docker Hub." }
        failure { echo "FAILURE: Build failed. Check Jacoco reports or Snyk logs." }
        always {
            cleanWs()
        }
    }
}