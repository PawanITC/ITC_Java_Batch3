pipeline {
    agent any

    tools {
        jdk 'jdk17'
    }

    environment {
        DOCKER_HUB_USER = 'abbasgureitc'
        IMAGE_NAME = 'user-service'
        REGISTRY_CREDENTIALS_ID = 'docker-hub-credentials'
        SNYK_TOKEN = credentials('snyk-auth-token')
    }

    stages {
        stage('Check Environment') {
            steps {
                sh 'java -version'
                sh 'docker version'
            }
        }

        stage('Build & Test') {
            steps {
                dir('backend/user-service') {
                    sh 'chmod +x gradlew'
                    sh './gradlew clean test jacocoTestReport'
                }
            }
        }

        stage('Quality Gate') {
            steps {
                // Using the specific path to avoid context confusion
                jacoco(
                    execPattern: 'backend/user-service/build/jacoco/*.exec',
                    classPattern: 'backend/user-service/build/classes/java/main',
                    sourcePattern: 'backend/user-service/src/main/java',
                    inclusionPattern: '**/src/main/java/**/*.class',
                    minimumInstructionCoverage: '70'
                )
            }
        }

        stage('Security Scan (Snyk)') {
            steps {
                dir('backend/user-service') {
                    echo 'Running Snyk Open Source Vulnerability Scan...'
                    // Added || true so the build doesn't die here while you're testing,
                    // but remove it when you want to enforce strict security!
                    sh 'snyk test --severity-threshold=high || echo "Snyk found issues, but continuing..." '
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('backend/user-service') {
                    script {
                        currentBuild.displayName = "#${env.BUILD_NUMBER} - ${IMAGE_NAME}"
                        currentBuild.description = "Built from branch ${env.BRANCH_NAME ?: 'jenkins-cicd'}"

                        // Capturing the image object correctly within the directory context
                        dockerImage = docker.build("${DOCKER_HUB_USER}/${IMAGE_NAME}:${env.BUILD_NUMBER}", ".")
                    }
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    // Push happens outside the dir() block because the dockerImage object
                    // already knows its identity, but uses the registry credentials.
                    docker.withRegistry('', REGISTRY_CREDENTIALS_ID) {
                        dockerImage.push()
                        dockerImage.push('latest')
                    }
                }
            }
        }
    }

    post {
        always {
            // This is the fix for the MissingContextVariableException.
            // Wrapping it in a script block or using deleteDir() is safer.
            script {
                try {
                    echo 'Cleaning up Jenkins Workspace...'
                    deleteDir()
                } catch (Exception e) {
                    echo "Cleanup failed but build is finished: ${e.message}"
                }
            }
        }
        success {
            echo 'Successfully deployed User Service to Docker Hub!'
        }
        failure {
            echo 'Build failed. Check the JaCoCo or Unit Test logs.'
        }
    }
}