pipeline {
    agent any

    tools {
        jdk 'jdk17'
    }

    environment {
        DOCKER_HUB_USER = 'abbasgureitc'
        IMAGE_NAME = 'user-service'
        REGISTRY_CREDENTIALS_ID = 'docker-hub-credentials'
        // Corrected to match your Jenkins Credential ID: snyk-token
        SNYK_TOKEN = credentials('snyk-token')
        dockerImage = ''
    }

    stages {
        stage('Check Environment') {
            steps {
                sh 'java -version'
                sh 'docker version'
            }
        }

        stage('Build & Test (The Transaction)') {
            steps {
                dir('backend/user-service') {
                    sh 'chmod +x gradlew'
                    /* PROFESSIONAL STANDARD:
                       'build' runs: compile -> test -> jar.
                       If tests fail, the JAR is never created,
                       preventing broken code from reaching Docker.
                    */
                    sh './gradlew clean build jacocoTestReport'
                }
            }
        }

        stage('Quality Gate') {
            steps {
                jacoco(
                    execPattern: 'backend/user-service/build/jacoco/*.exec',
                    classPattern: 'backend/user-service/build/classes/java/main',
                    sourcePattern: 'backend/user-service/src/main/java',
                    inclusionPattern: '**/src/main/java/**/*.class',
                    minimumInstructionCoverage: '70'
                )
            }
        }

        stage('Security Scan (Snyk)') {
            steps {
                dir('backend/user-service') {
                    echo 'Running Snyk Open Source Vulnerability Scan...'
                    sh "snyk auth ${SNYK_TOKEN}"
                    sh 'snyk test --severity-threshold=high || echo "Snyk found high issues, review required."'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('backend/user-service') {
                    script {
                        // Verifies the JAR exists in the console logs
                        sh 'ls -R build/libs/'

                        currentBuild.displayName = "#${env.BUILD_NUMBER} - ${IMAGE_NAME}"
                        currentBuild.description = "Branch: ${env.BRANCH_NAME ?: 'main'}"

                        // Build context is '.' because we are inside backend/user-service
                        dockerImage = docker.build("${DOCKER_HUB_USER}/${IMAGE_NAME}:${env.BUILD_NUMBER}", ".")
                    }
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    docker.withRegistry('', REGISTRY_CREDENTIALS_ID) {
                        dockerImage.push()
                        dockerImage.push('latest')
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'SUCCESS: User Service is live on Docker Hub.'
        }
        failure {
            echo 'FAILURE: Check unit tests or Snyk logs.'
        }
        always {
            // Using a script block to safely handle cleanup context
            script {
                try {
                    cleanWs()
                } catch (Exception e) {
                    echo "Cleanup failed or workspace already gone: ${e.message}"
                }
            }
        }
    }
}