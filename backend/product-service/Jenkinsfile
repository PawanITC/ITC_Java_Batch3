pipeline {
    agent any
    environment {
        DOCKER_USER     = 'ipenitcdocker'
        REPO_NAME       = 'product-service'
        IMAGE_NAME      = "${DOCKER_USER}/${REPO_NAME}"
        CREDS_ID        = 'DOCKER_HUB_CREDS'
        VERSION         = "1.0.${env.BUILD_NUMBER}"
        PROJECT_DIR     = 'backend/product-service'
    }

    stages {
        stage('Build Artifact') {
            steps {
                dir("${env.PROJECT_DIR}") {
                    sh "chmod +x gradlew"
                    sh "./gradlew clean build -x test"
                }
            }
        }

        stage('Build Image') {
            steps {
                dir("${env.PROJECT_DIR}") {
                    sh "docker build -t ${IMAGE_NAME}:${VERSION} -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Push to Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: "${env.CREDS_ID}",
                                                 passwordVariable: 'DOCKER_PASS',
                                                 usernameVariable: 'DOCKER_USER_ID')]) {
                    sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER_ID --password-stdin"
                    sh "docker push ${IMAGE_NAME}:${VERSION}"
                    sh "docker push ${IMAGE_NAME}:latest"
                }
            }
        }
    }

    post {
        always {
            sh "docker logout || true"
            sh "docker rmi ${IMAGE_NAME}:${VERSION} ${IMAGE_NAME}:latest || true"
        }
    }
}