# ==================================================
# Funkart Payment Service - Git Ignore
# ==================================================

# --- Gradle Essentials (CRITICAL for Jenkins) ---
!gradlew
!gradlew.bat
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# --- Build Outputs (Keep Git Clean) ---
.gradle
build/
bin/
out/
.apt_generated

# --- IDEs & Editors ---
.idea/
*.iws
*.iml
*.ipr
.vscode/
.settings/
.classpath
.project
.factorypath
.springBeans
.sts4-cache

# --- Secrets & Environment (SECURITY) ---
# This is the most important part for Payments!
.env
*.env
.env.local

# --- OS & Logs ---
.DS_Store
Thumbs.db
*.log

# --- Specific Negations ---
# Only use these if you have specific generated source requirements
# !**/src/main/resources/static/build/