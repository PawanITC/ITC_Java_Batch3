pipeline {
    agent any

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test') {
            steps {
                sh 'cd backend/catalogue-service && ./gradlew test --no-daemon'
            }
        }

        stage('Build JAR') {
            steps {
                sh 'cd backend/catalogue-service && ./gradlew build -x test --no-daemon'
            }
        }

        stage('Build & Push Image (ECR)') {
            steps {
                sh '''
                cd backend/catalogue-service

                aws ecr get-login-password --region eu-west-2 \
                | docker login --username AWS --password-stdin 666127452756.dkr.ecr.eu-west-2.amazonaws.com

                docker build -t catalogue-service .
                docker tag catalogue-service 666127452756.dkr.ecr.eu-west-2.amazonaws.com/catalogue-service:latest
                docker push 666127452756.dkr.ecr.eu-west-2.amazonaws.com/catalogue-service:latest
                '''
            }
        }

        stage('Deploy to EKS') {
            steps {
                sh '''
                kubectl apply -f k8s/
                '''
            }
        }
    }
}