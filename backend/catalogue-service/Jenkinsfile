pipeline {
    agent any

    stages {

        stage('Test') {
            steps {
                sh 'cd backend/catalogue-service && ./gradlew test'
            }
        }

        stage('Build') {
            steps {
                sh 'cd backend/catalogue-service && ./gradlew build -x test'
            }
        }

        stage('Deploy (Docker Compose)') {
            steps {
                sh '''
                cd backend/catalogue-service
                docker-compose down || true
                docker-compose up -d --build
                '''
            }
        }

        stage('Deploy (Docker)') {
            steps {
                sh '''
                docker stop catalogue-service || true
                docker rm catalogue-service || true
                docker build -t catalogue-service backend/catalogue-service
                docker run -d -p 8081:8081 --name catalogue-service catalogue-service
                '''
            }
        }

    }
}