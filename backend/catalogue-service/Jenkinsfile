pipeline {
    agent any

    stages {

        stage('Test') {
            steps {
                sh 'cd backend/catalogue-service && ./gradlew test'
            }
        }

        stage('Build') {
            steps {
                sh 'cd backend/catalogue-service && ./gradlew build -x test'
            }
        }

        stage('Deploy (Docker Compose)') {
            steps {
                sh '''
                cd backend/catalogue-service
                docker-compose down || true
                docker-compose up -d --build
                '''
            }
        }

        //PRODUCTION (Needed so that app can boot first)
        stage('Wait for Service Health') {
            steps {
                sh '''
                echo "Waiting for service to be ready..."

                timeout=60
                interval=3
                elapsed=0

                while [ $elapsed -lt $timeout ]; do
                  if curl -s http://host.docker.internal:8081/actuator/health | grep '"status":"UP"' > /dev/null; then
                    echo "Service is UP"
                    exit 0
                  fi

                  echo "Still starting..."
                  sleep $interval
                  elapsed=$((elapsed + interval))
                done

                echo "Service failed to start in time"
                exit 1
                '''
            }
        }

        stage('Performance Test (JMeter)') {
            steps {
                sh '''
                cd backend/catalogue-service/jmeter

                # CLEAN OLD FILES
                rm -rf report results.jtl jmeter.log || true

                docker run --rm \
                  -v /var/lib/docker/volumes/jenkins_home/_data/workspace/catalogue-pipeline/backend/catalogue-service/jmeter:/tests \
                  --add-host=host.docker.internal:host-gateway \
                  justb4/jmeter \
                  -n \
                  -t /tests/catalogue-docker-test.jmx \
                  -l /tests/results.jtl \
                  -j /tests/jmeter.log \
                  -e -o /tests/report \
                  -JtestType=high
                '''
            }
        }

        stage('Archive JMeter Report') {
            steps {
                archiveArtifacts artifacts: 'backend/catalogue-service/jmeter/**', fingerprint: true
            }
        }

    }
}