pipeline {
    agent any

    environment {
        WORKSPACE_JMETER_DIR = "${WORKSPACE}/backend/catalogue-service/jmeter"
        HOST_JMETER_DIR = "/var/lib/docker/volumes/jenkins_home/_data/workspace/catalogue-pipeline/backend/catalogue-service/jmeter"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify JMX File') {
            steps {
                sh '''
                if grep -q "host.docker.internal" backend/catalogue-service/jmeter/catalogue-docker-test.jmx; then
                    echo "JMX INVALID"
                    exit 1
                else
                    echo "JMX OK"
                fi
                '''
            }
        }

        stage('Test') {
            steps {
                sh 'cd backend/catalogue-service && ./gradlew test --no-daemon'
            }
        }

        stage('Build') {
            steps {
                sh 'cd backend/catalogue-service && ./gradlew build -x test --no-daemon'
            }
        }

        stage('Deploy (Docker Compose)') {
            steps {
                sh '''
                cd backend/catalogue-service
                docker-compose down || true
                docker-compose up -d --build
                '''
            }
        }

        stage('Wait for Service Health') {
            steps {
                sh '''
                timeout=60
                elapsed=0

                until curl -s http://catalogue-service:8081/actuator/health | grep '"status":"UP"' > /dev/null; do
                    if [ $elapsed -ge $timeout ]; then
                        docker logs catalogue-service
                        exit 1
                    fi
                    sleep 3
                    elapsed=$((elapsed+3))
                done
                '''
            }
        }

        stage('Performance Test (JMeter)') {
            steps {
                sh '''
                rm -rf "${WORKSPACE_JMETER_DIR}/results.jtl" \
                       "${WORKSPACE_JMETER_DIR}/jmeter.log" \
                       "${WORKSPACE_JMETER_DIR}/report-${BUILD_NUMBER}"

                docker run --rm \
                  --network catalogue-service_default \
                  -v "${HOST_JMETER_DIR}:/tests" \
                  justb4/jmeter \
                  -n \
                  -t /tests/catalogue-docker-test.jmx \
                  -l /tests/results.jtl \
                  -j /tests/jmeter.log \
                  -JtestType=normal

                docker run --rm \
                  --network catalogue-service_default \
                  -v "${HOST_JMETER_DIR}:/tests" \
                  justb4/jmeter \
                  -g /tests/results.jtl \
                  -o /tests/report-${BUILD_NUMBER}

                test -f "${WORKSPACE_JMETER_DIR}/results.jtl"
                test -f "${WORKSPACE_JMETER_DIR}/report-${BUILD_NUMBER}/index.html"
                '''
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'backend/catalogue-service/jmeter/**', fingerprint: true

            publishHTML([
                reportDir: "backend/catalogue-service/jmeter/report-${env.BUILD_NUMBER}",
                reportFiles: 'index.html',
                reportName: 'JMeter Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: false
            ])
        }
    }
}