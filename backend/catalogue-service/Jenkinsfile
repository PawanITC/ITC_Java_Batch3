pipeline {
    agent any

    stages {

        stage('Test') {
            steps {
                sh 'cd backend/catalogue-service && ./gradlew test'
            }
        }

        stage('Build') {
            steps {
                sh 'cd backend/catalogue-service && ./gradlew build -x test'
            }
        }

        stage('Deploy (Docker Compose)') {
            steps {
                sh '''
                cd backend/catalogue-service
                docker-compose down || true
                docker-compose up -d --build
                '''
            }
        }

        stage('Wait for Service Health') {
            steps {
                sh '''
                echo "Waiting for service to be ready..."

                timeout=60
                interval=3
                elapsed=0

                while [ $elapsed -lt $timeout ]; do
                  if curl -s http://host.docker.internal:8081/actuator/health | grep '"status":"UP"' > /dev/null; then
                    echo "Service is UP"
                    exit 0
                  fi

                  echo "Still starting..."
                  sleep $interval
                  elapsed=$((elapsed + interval))
                done

                echo "Service failed to start in time"
                exit 1
                '''
            }
        }

        stage('Find JMeter Test File') {
            steps {
                sh '''
                cd backend/catalogue-service/jmeter
                echo "=== Looking for JMX files ==="
                echo "Current directory: $(pwd)"
                echo ""
                echo "All files in current directory:"
                ls -la
                echo ""
                echo "Searching for .jmx files in backend/catalogue-service:"
                find ../.. -name "*.jmx" -type f
                echo ""
                echo "Searching in whole workspace:"
                find /var/jenkins_home/workspace/catalogue-pipeline -name "*.jmx" -type f
                '''
            }
        }

        stage('Performance Test (JMeter)') {
            steps {
                sh '''
                cd backend/catalogue-service/jmeter

                rm -rf report results.jtl jmeter.log

                # Get workspace directory
                WORKSPACE_DIR=$(pwd)
                echo "Workspace directory: $WORKSPACE_DIR"

                # First, let's find where the JMX file is
                echo "=== Finding JMX file ==="
                JMX_FILE=$(find /var/jenkins_home/workspace/catalogue-pipeline -name "catalogue-docker-test.jmx" -type f | head -1)

                if [ -z "$JMX_FILE" ]; then
                    echo "ERROR: catalogue-docker-test.jmx not found anywhere!"
                    echo "Searching for any .jmx files:"
                    find /var/jenkins_home/workspace/catalogue-pipeline -name "*.jmx" -type f
                    exit 1
                fi

                echo "Found JMX file at: $JMX_FILE"

                # Get the directory containing the JMX file
                JMX_DIR=$(dirname "$JMX_FILE")
                echo "JMX directory: $JMX_DIR"

                # Copy the JMX file to our jmeter directory if it's not already there
                if [ "$JMX_DIR" != "$WORKSPACE_DIR" ]; then
                    echo "Copying JMX file to jmeter directory..."
                    cp "$JMX_FILE" "$WORKSPACE_DIR/"
                fi

                # Verify the file is now in the current directory
                if [ ! -f catalogue-docker-test.jmx ]; then
                    echo "ERROR: catalogue-docker-test.jmx still not in current directory!"
                    ls -la
                    exit 1
                fi

                echo "=== Running JMeter test ==="
                docker run --rm \
                  -v $WORKSPACE_DIR:/tests \
                  --add-host=host.docker.internal:host-gateway \
                  justb4/jmeter \
                  -n \
                  -t /tests/catalogue-docker-test.jmx \
                  -l /tests/results.jtl \
                  -j /tests/jmeter.log \
                  -JtestType=high \
                  -Jjmeter.save.saveservice.output_format=csv \
                  -Jjmeter.save.saveservice.timestamp_format=ms \
                  -Jjmeter.save.saveservice.print_field_names=true

                # Check if results.jtl was created
                if [ ! -f results.jtl ]; then
                    echo "ERROR: results.jtl was not created!"
                    exit 1
                fi

                echo "results.jtl created successfully"
                ls -la results.jtl

                echo "=== Generating HTML report ==="
                docker run --rm \
                  -v $WORKSPACE_DIR:/tests \
                  justb4/jmeter \
                  -g /tests/results.jtl \
                  -o /tests/report

                # Check if report was generated
                if [ ! -f report/index.html ]; then
                    echo "ERROR: report/index.html was not generated!"
                    echo "Contents of report directory:"
                    ls -la report/ || echo "report directory doesn't exist"
                    exit 1
                fi

                echo "=== Report generated successfully ==="
                ls -la report/

                # Fix permissions so Jenkins can read them
                chmod -R 777 report/
                '''
            }
        }

        stage('Verify Report Files') {
            steps {
                sh '''
                cd backend/catalogue-service/jmeter
                echo "=== Verifying report files ==="
                echo "Current directory: $(pwd)"
                echo ""
                echo "=== Full directory structure ==="
                find . -type f -name "*.html" | head -20
                echo ""
                echo "=== Checking if index.html exists ==="
                if [ -f report/index.html ]; then
                    echo "✅ index.html exists"
                    ls -la report/index.html
                    echo ""
                    echo "=== First few lines of index.html ==="
                    head -20 report/index.html
                else
                    echo "❌ index.html NOT found!"
                    echo "Contents of report directory:"
                    ls -la report/ || echo "report directory doesn't exist"
                fi
                '''
            }
        }

        stage('Archive JMeter Report') {
            steps {
                archiveArtifacts artifacts: 'backend/catalogue-service/jmeter/**', fingerprint: true

                publishHTML([
                    reportDir: 'backend/catalogue-service/jmeter/report',
                    reportFiles: 'index.html',
                    reportName: 'JMeter Performance Report',
                    allowMissing: false,
                    keepAll: true,
                    alwaysLinkToLastBuild: true
                ])
            }
        }

    }
}