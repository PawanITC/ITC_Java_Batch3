pipeline {
    agent any

    tools {
        jdk 'jdk17'
    }

    environment {
        DOCKER_HUB_USER = 'abbasgureitc'
        IMAGE_NAME = 'api-gateway'
        REGISTRY_CREDENTIALS_ID = 'docker-hub-credentials'
        SNYK_TOKEN = credentials('snyk-token')
        dockerImage = ''
    }

    stages {
        stage('Check Environment') {
            steps {
                sh 'java -version'
                sh 'docker version'
            }
        }

        stage('Build & Test') {
            steps {
                dir('backend/api-gateway') {
                    script {
                        // Grant execute permission to the wrapper
                        sh "chmod +x gradlew"

                        sh "./gradlew clean build jacocoTestReport \
                            -Dspring.profiles.active=test \
                            --no-daemon --stacktrace"
                    }
                }
            }
        }

//         stage('Security Scan (Snyk)') {
//             steps {
//                 dir('backend/api-gateway') {
//                     script {
//                         // Retry the scan up to 3 times if it fails due to network/server issues
//                         retry(3) {
//                             // Added --timeout to give the remote server more breathing room
//                             sh 'snyk test --severity-threshold=high --timeout=300'
//                         }
//                         sh 'snyk monitor'
//                     }
//                 }
//             }
//         }


        stage('Security Scan (Snyk)') {
            steps {
                dir('backend/api-gateway') {
                    script {
                        // This block allows the pipeline to continue even if Snyk returns a 500
                        catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                            sh 'snyk test --severity-threshold=high'
                            sh 'snyk monitor'
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                // Modern replacement for the deprecated Jacoco plugin
                jacoco(
                    execPattern: '**/build/jacoco/*.exec',
                    classPattern: '**/build/classes/java/main',
                    sourcePattern: '**/src/main/java',
                    inclusionPattern: '**/*.class',
                    minimumLineCoverage: '70',
                )
            }
        }


        stage('Build Docker Image') {
            steps {
                dir('backend/api-gateway') {
                    script {
                        sh 'ls -R build/libs/'
                        currentBuild.displayName = "#${env.BUILD_NUMBER} - ${IMAGE_NAME}"
                        dockerImage = docker.build("${DOCKER_HUB_USER}/${IMAGE_NAME}:${env.BUILD_NUMBER}", ".")
                    }
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    docker.withRegistry('', REGISTRY_CREDENTIALS_ID) {
                        dockerImage.push()
                        dockerImage.push('latest')
                    }
                }
            }
        }
    }

    post {
        success { echo "SUCCESS: ${IMAGE_NAME} is deployed to Docker Hub." }
        failure { echo "FAILURE: Build failed. Check routing tests, security filter logs, or Snyk reports." }
        always {
            cleanWs()
        }
    }
}