pipeline {
    agent any

    tools {
        jdk 'jdk17'
    }

    environment {
        DOCKER_HUB_USER = 'abbasgureitc'
        IMAGE_NAME = 'api-gateway'
        REGISTRY_CREDENTIALS_ID = 'docker-hub-credentials'
        SNYK_TOKEN = credentials('snyk-token')
        dockerImage = ''
    }

    stages {
        stage('Check Environment') {
            steps {
                sh 'java -version'
                sh 'docker version'
            }
        }

        stage('Build & Test') {
            steps {
                dir('backend/api-gateway') {
                    script {
                        def jdkPath = tool name: 'jdk17', type: 'jdk'
                        withEnv(["JAVA_HOME=${jdkPath}", "PATH+JDK=${jdkPath}/bin"]) {
                            sh 'chmod +x gradlew'
                            // Added -Dspring.profiles.active=test to ensure your mock config is loaded
                            sh "./gradlew clean build jacocoTestReport --no-daemon \
                                -Dspring.profiles.active=test \
                                -Dorg.gradle.java.home=${jdkPath} \
                                --stacktrace --info"
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                // Modern replacement for the deprecated Jacoco plugin
                jacoco(
                    execPattern: '**/build/jacoco/*.exec',
                    classPattern: '**/build/classes/java/main',
                    sourcePattern: '**/src/main/java',
                    inclusionPattern: '**/*.class',
                    minimumLineCoverage: '70',
                    maximumLineCoverage: '80'
                )
            }
        }

        stage('Security Scan (Snyk)') {
            steps {
                dir('backend/api-gateway') {
                    script {
                        // Added chmod +x gradlew here too as Snyk often needs to run Gradle locally to resolve dependencies
                        sh 'chmod +x gradlew'
                        sh "snyk auth ${SNYK_TOKEN}"
                        sh 'snyk test --severity-threshold=high || echo "Snyk found vulnerabilities in API Gateway, review logs."'
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('backend/api-gateway') {
                    script {
                        sh 'ls -R build/libs/'
                        currentBuild.displayName = "#${env.BUILD_NUMBER} - ${IMAGE_NAME}"
                        dockerImage = docker.build("${DOCKER_HUB_USER}/${IMAGE_NAME}:${env.BUILD_NUMBER}", ".")
                    }
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    docker.withRegistry('', REGISTRY_CREDENTIALS_ID) {
                        dockerImage.push()
                        dockerImage.push('latest')
                    }
                }
            }
        }
    }

    post {
        success { echo "SUCCESS: ${IMAGE_NAME} is deployed to Docker Hub." }
        failure { echo "FAILURE: Build failed. Check routing tests, security filter logs, or Snyk reports." }
        always {
            cleanWs()
        }
    }
}